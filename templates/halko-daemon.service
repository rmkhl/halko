[Unit]
Description=Halko Service: %i
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=0

[Service]
Type=simple
ExecStart=/opt/halko/%i -c /etc/opt/halko.cfg
Restart=on-failure
RestartSec=5s
User=halko
Group=halko
# Graceful termination settings
TimeoutStopSec=10s
KillMode=mixed
KillSignal=SIGTERM

[Install]
WantedBy=multi-user.target
